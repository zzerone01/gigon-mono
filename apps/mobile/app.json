{
  "expo": {
    "name": "GigOn",
    "slug": "gigon",
    "scheme": "gigon",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "backgroundColor": "#FFFFFF",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "io.gigon.app"
    },
    "android": {
      "package": "io.gigon.app",
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "expo-splash-screen",
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "GigOn only uses your location to show gigs within 2–3 km. Your exact location is never shown to other users."
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/android-icon-monochrome.png",
          "color": "#103F96"
        }
      ]
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "5fae70af-acf1-402c-8d34-0853eabdc839"
      }
    },
    "owner": "zeronej",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/5fae70af-acf1-402c-8d34-0853eabdc839"
    }
  }
}
