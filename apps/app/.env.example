# Supabase — local dev values come from `npx supabase status` at the repo root.
# For production, use the project's URL + anon key (Settings → API).
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZS1kZW1vIiwicm9sZSI6ImFub24iLCJleHAiOjE5ODM4MTI5OTZ9.CRXP1A7WOeoJeXxjNni43kdQwgnWNReilDMblYTn_I0

# Google Maps (optional — the app falls back to the stylized SVG map without it).
# Create a key at console.cloud.google.com with "Maps JavaScript API" enabled.
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=
NEXT_PUBLIC_GOOGLE_MAPS_MAP_ID=

# Server-only Postgres connection for the write API (drizzle + postgres.js).
# Cloud: Supavisor TRANSACTION pooler (:6543) from Dashboard > Connect.
# Local stack: postgresql://postgres:postgres@127.0.0.1:54322/postgres
DATABASE_URL=

# PostHog product analytics — same project as apps/web (gigon.io landing).
# The key is public (ships in the browser bundle); the server-side funnel
# events (lib/server/analytics.ts) use the same key. Leave the placeholder
# to keep analytics off in local dev.
NEXT_PUBLIC_POSTHOG_KEY=phc_REPLACE_ME
# US cloud: https://us.i.posthog.com  ·  EU cloud: https://eu.i.posthog.com
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
